// ============================================================
//  Reglas de seguridad de Firestore - Inventario FVIECOM
// ------------------------------------------------------------
//  Estas reglas protegen los datos: SOLO usuarios con sesion
//  iniciada (login) pueden leer y escribir el inventario.
//
//  Como aplicarlas:
//   Consola de Firebase -> Firestore Database -> pestana "Reglas"
//   -> pega este contenido -> "Publicar".
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cualquier usuario autenticado puede leer y escribir.
    match /materiales/{doc} {
      allow read, write: if request.auth != null;
    }

    match /movimientos/{doc} {
      allow read, write: if request.auth != null;
    }

    match /ordenes/{doc} {
      allow read, write: if request.auth != null;
    }

    match /kits/{doc} {
      allow read, write: if request.auth != null;
    }

    match /categorias/{doc} {
      allow read, write: if request.auth != null;
    }

    // Todo lo demas queda bloqueado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
