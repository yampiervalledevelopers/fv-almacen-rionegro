{
  "name": "fv-almacen-rionegro",
  "version": "1.0.0",
  "description": "Inventario FVIECOM - App de escritorio para control de materiales de obra electrica (Aeropuerto Jose Maria Cordova, Rionegro)",
  "author": "FVIECOM S.A.S",
  "license": "UNLICENSED",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/logic.test.js",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist": "electron-builder"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fviecom.almacen",
    "productName": "Inventario FVIECOM",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "src/renderer/assets/logo-fviecom.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Inventario FVIECOM"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/renderer/assets/logo-fviecom.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/renderer/assets/logo-fviecom.png"
    }
  }
}
